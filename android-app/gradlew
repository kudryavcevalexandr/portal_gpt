#!/usr/bin/env sh

# Minimal Gradle wrapper launcher for initial project structure bootstrap.
WRAPPER_JAR="$(dirname "$0")/gradle/wrapper/gradle-wrapper.jar"

if [ ! -f "$WRAPPER_JAR" ]; then
  echo "gradle-wrapper.jar not found. Run 'gradle wrapper' in android-app/ to generate full wrapper files."
  exit 1
fi

exec java -jar "$WRAPPER_JAR" "$@"
